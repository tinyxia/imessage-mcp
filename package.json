{
  "name": "imessage-mcp-server",
  "version": "2.0.0",
  "description": "MCP server and AI bridge for iMessage on macOS",
  "type": "module",
  "bin": {
    "imessage-mcp-server": "./bin/imessage-mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "preferUnplugged": true,
  "scripts": {
    "start": "node bin/imessage-mcp-server --server",
    "bridge": "node bin/imessage-mcp-server --bridge",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "imessage",
    "imessage-mcp",
    "imessage-mcp-server",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "macos",
    "messages",
    "icloud",
    "apple",
    "ai",
    "bridge",
    "agent"
  ],
  "author": "tinyxia",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyxia/imessage-mcp.git"
  },
  "homepage": "https://github.com/tinyxia/imessage-mcp#readme",
  "bugs": {
    "url": "https://github.com/tinyxia/imessage-mcp/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "openai": "^4.0.0"
  }
}
